{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "presentation": {
    "echo": false,
    "reveal": "always",
    "focus": false,
    "panel": "shared",
    "showReuseMessage": false
  },
  "tasks": [
    {
      "label": "Launch Everything",
      "dependsOn": ["Run Web", "Run Bot"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Run Web",
      "type": "shell",
      "command": "npm run dev -w web",
      "isBackground": true,
      "icon": { "id": "server", "color": "terminal.ansiYellow" },
      "presentation": {
        "group": "watcher-group"
      }
    },
    {
      "label": "Run Bot",
      "type": "shell",
      "command": "npm run start -w bot",
      "isBackground": true,
      "icon": { "id": "robot", "color": "terminal.ansiMagenta" },
      "presentation": {
        "group": "watcher-group"
      }
    }
  ]
}
