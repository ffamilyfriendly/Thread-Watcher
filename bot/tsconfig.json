{
  "compilerOptions": {
    "target": "ESNext",
    "module": "nodenext",
    "strict": true,
    "moduleResolution": "nodenext",
    "importHelpers": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "removeComments": true,
    "typeRoots": ["node_modules/@types"],
    "sourceMap": false,
    "noEmit": true,
    "paths": {
      "@watcher/shared": ["../packages/shared/index.ts"],
      "@providers/*": ["./src/providers/*"],
      "@generated/*": ["./src/.generated/*"],
      "#/*": ["./src/*"]
    }
  },
  "files": ["src/index.ts", "src/bot.ts", "src/scripts/deploy.ts", "src/scripts/gen_docs.ts"],
  "include": ["src/**/*.ts"],
  "exclude": ["**/node_modules", "dist"]
}
