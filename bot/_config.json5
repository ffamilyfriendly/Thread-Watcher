{
  tokens: {
    // The "token" from the bot page of an application -> https://discord.com/developers/applications
    discord: '',
    // Top.gg token used for updating live stats
    topgg: 'secret',
  },
  paywall: {
    // enbaled: false will make the bot think every server has premium, which you probably want.
    enabled: false,
    // The SKU of the TW+ tier
    basic_sku: '1420338984797601872',
    // Controlls how long to keep ticket transcripts.
    // if you're self hosting I recoment setting a high number on retain_tickets_days_premium to keep tickets "forever"
    retain_tickets_days_free: 14,
    retain_tickets_days_premium: 1337,
    // How often the bot will pull down subscriptions/entitlements from the payment providers and ensure the local DB is kept up to date
    reconsile_payments_schedule: '0 */6 * * *',
  },
  web: {
    enabled: true,
    port: 2003,
    hostname: 'https://threadwatcher.xyz',
    // This secret is used to ensure data coming in from the sveltekit dashboard is legitimate.
    // Make sure the sveltekit .env has the exact same secret
    shared_secret: 'xX_zecret_value_Xx',
    // Set this up in your bot's top.gg entry as well.
    // Note: Thread-Watcher uses the depracted Top.gg webhook system
    topgg_webhook_secret: 'STIGMAN_GAMING',
    // The max time we allow processing an API call to take before we start warning
    ms_request_considered_slow: 200,
  },
  // String array of Discord ID's of anyone considered an 'owner' of the bot.
  // Owners have absolute permissions and will be able to do anything, anywhere, for the bot
  owners: ['286224826170081290'],
  // The ID of the bot. You can get this in the Discord application page
  clientID: '1202623821010436147',
  // The Discord snowflake of your "dev server"
  // Any local commands (such as dev only commands) will be registered here
  devServer: '1063430373394100335',
  database: {
    flavour: 'mysql',
    host: 'localhost',
    user: 'your_db_user',
    password: 'secret',
    name: 'threadwatcher',
    connection_limit: 5,
    // Redis is currently un-authenticated so these values will not do anything.
    // In the future I may use authenticated redis
    redis: {
      user: 'user',
      password: 'password',
    },
    // Crontab of how often you want to create database backups
    backup_interval: '0 0 * * *',
    // true = your backups will be uploaded to the S3 bucket configured below
    upload_backup_to_bucket: false,
    // How often to clean up servers the bot has left, expired tickets, and so forth. Crontab
    run_cleanup_tasks: '*/30 * * * *',
    // How many backups to keep locally. Database backups are deleted in a FIFO order
    keep_local_files_amount: 5,
    // How long to keep servers in the DB after the bot has been removed from them.
    keep_dead_servers_in_db_seconds: 2592000,
  },
  ai: {
    // How much AI "tokens" to allocate
    // 500000 is equal to about 0.5EUR in actual AI processing costs.
    monthly_tokens_premium: 9999999999999999,
    initial_free_tokens: 9999999999999999,
    vote_reward_tokens: 9999999999999999,
    // Your mistral AI api key
    mistral_key: 'secret',
    // The Agent ID's to use. You can find the prompts used by the official bot in /docs/agents.md
    agents: {
      regex_agent: 'ag_REGEX_AGENT_ID',
      issue_narrower: 'ag_ISSUE_NARROWER_ID',
      ticket_summarizer: 'ag_TICKET_SUMMARIZER_ID',
    },
  },
  // Your S3 compatible storage credz. The official Thread-Watcher bot uses R2, but you're free to pick anything as long as it's bun S3 compatible
  bucket_storage: {
    url: 'https://xxxx.r2.cloudflarestorage.com',
    secret_access_key: 'xxxx',
    access_key_id: 'xxxx',
    // These limits reffer to how large ticket transcript file attachments to allow
    free_file_limit: 20970000, //20 megabytes
    global_file_limit: 525300000, //500 megabytes (discord max)
  },
  style: {
    error: {
      colour: '#ef4444',
      emoji: '<:statusurgent:960959148848214017>',
    },
    success: {
      colour: '#22c55e',
      emoji: '<:statusgood:960960196425957447>',
    },
    info: {
      colour: '#197BBD',
      emoji: '<:statusinfo:960960247571300353>',
    },
    warning: {
      colour: '#F18F01',
      emoji: '⚠️',
    },
    premium: {
      colour: '#ffc34b',
      emoji: '👑',
    },
  },
  // Limited mode will stop TW from processing most Discord events. You want this as "false" unless things are crashing and burning (been there)
  limited_mode: false,
  // This is the key used to encrypt any ticket message content data at rest. Keep it secret m'kay?
  crypto_key: 'xxx_discord_is_angry_if_you_dont_encrypt_which_is_fair',
  modules: {
    // Any threads created by users with these ID's will be watched if setting `NEEDLE_INTEGRATION` is enabled for a server.
    // 878399831238909952: Needle
    thread_create_bots: ['878399831238909952'],
  },
}
