{
  tokens: {
    // Your discord bot secret. Keep this secret (duh)
    discord: 'XXXX',
    topgg: 'secret',
  },
  paywall: {
    // You probably want to keep this false.
    enabled: false,
    basic_sku: '1326343068533653635',
    // how long to retain any tickets past their creation data in the database
    // !! Ensure you also set appropriate auto-deletion lifecycles on your S3 bucket to avoid filling it with attachments
    retain_tickets_days_free: 14,
    retain_tickets_days_premium: 90,
  },
  web: {
    enabled: true,
    port: 2003,
    hostname: 'https://threadwatcher.xyz',
    // The shared secret is used to verify requests coming from the dashboard/web are legitimate.
    // Pick a safe secret and ensure you define the same secret in the web config
    shared_secret: 'XXXX',
  },
  // an array of discord IDs of user with owner privledges. I suggest removing my ID (286224826170081290)
  owners: ['286224826170081290'],
  clientID: '1202623821010436147',
  // The discord server ID of your development (or private) server where the developer only commands will be registered
  devServer: '1063430373394100335',
  /*
    flavour: 'mysql',
    redis: {
      user: 'xxxx',
      password: 'xxx',
    },
    backup_path: './backups',
    backup_interval: '0 0 * * *',
    upload_backup_to_bucket: false,
    run_cleanup_tasks: '* * * * *',
    keep_local_files_amount: 5,
    keep_dead_servers_in_db_seconds: 2592000,
  */
  database: {
    flavour: 'sqlite',
    /* Redis is currently implemented without 'user' or 'password'. You can therefore set these to whatever you'd like */
    redis: {
      user: 'stigman_gaming',
      password: 'fortnite_idk',
    },
    // The path (relative or absolute) to the folder where Thread-Watcher will leave it's database dumps
    // Check /bot/src/routines/do_database_backup.ts for exact implementation
    backup_path: './backups',
    // How often Thread-Watcher should take database backups.
    // '0 0 * * *' will generate a backup daily @ midnight. tip: https://crontab.cronhub.io/
    backup_interval: '0 0 * * *',
    // Wheter or not to upload database dumps to the S3 bucket provided below
    upload_backup_to_bucket: false,
    // How often cleanup tasks should run. Cleanup tasks include removing data from servers the bot has left, removing expired tickets, and so forth.
    // Check /bot/src/routines/do_cleanup.ts for exact implementation
    run_cleanup_tasks: '*/30 * * * *', // every half hour
    // How many database dumps to keep locally. Files will be deleted in a FIFO order
    keep_local_files_amount: 5,
    // A server is considered 'dead' from the moment the bot is kicked from the server. When the bot re-joins a server this field is nullified (the countdown stops)
    keep_dead_servers_in_db_seconds: 2592000,
  },
  ai: {
    monthly_tokens_premium: 999999999999,
    initial_free_tokens: 999999999999,
    /* AI (can) be used in ticket modules & for creating regexes on the fly. You can get your agent key on https://console.mistral.ai/home?profile_dialog=api-keys */
    mistral_key: 'XXXX',
    agents: {
      /*
        Define your agents on https://console.mistral.ai/build/agents
        The agent prompts & configuration we use is available in the /docs folder
      */
      regex_agent: 'ag_XXXX',
      issue_narrower: 'ag_XXXX',
      ticket_summarizer: 'ag_XXXX',
    },
  },
  /* The bucket storage is used to store images, database backups, and ticket pipeline log-files. You may use any S3 compatible provider */
  bucket_storage: {
    url: 'https://XXXX.r2.cloudflarestorage.com',
    secret_access_key: 'XXXX',
    access_key_id: 'XXXX',
    free_file_limit: 20970000, //20 megabytes
    global_file_limit: 525300000, //500 megabytes (discord max)
  },
  style: {
    error: {
      colour: '#D00000',
      emoji: '<:statusurgent:960959148848214017>',
    },
    success: {
      colour: '#4C9F70',
      emoji: '<:statusgood:960960196425957447>',
    },
    info: {
      colour: '#197BBD',
      emoji: '<:statusinfo:960960247571300353>',
    },
    warning: {
      colour: '#F18F01',
      emoji: '⚠️',
    },
  },
  /* This crypto key is used to encrypt message content provided by users of the ticket and can be generated in the same way as the 'shared_secret' above */
  crypto_key: 'CRYPTO_KEY',
}
